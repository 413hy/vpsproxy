# Never commit a filled .env file.
VPSPM_TELEGRAM_BOT_TOKEN=replace-with-bot-token
VPSPM_ADMIN_USER_IDS=6977085303
VPSPM_ALLOWED_CHAT_IDS=
VPSPM_REQUIRE_PRIVATE_CHAT=true
VPSPM_DATABASE_URL=sqlite+aiosqlite:////opt/vps-proxy-manager/data/app.db
VPSPM_SECRET_KEY=replace-with-fernet-key-from-vps-proxy-manager-keygen
VPSPM_LOG_LEVEL=INFO
VPSPM_DATA_DIR=/opt/vps-proxy-manager/data
VPSPM_ALLOW_PRIVATE_SUBSCRIPTION_URLS=false
VPSPM_SUBSCRIPTION_MAX_BYTES=1048576
VPSPM_SUBSCRIPTION_TIMEOUT_SECONDS=12
VPSPM_SUBSCRIPTION_MAX_REDIRECTS=3
VPSPM_SPEEDTEST_CONCURRENCY=3
VPSPM_REMOTE_ROLLBACK_SECONDS=120
